<Window x:Class="AutoCADToRevitApplication.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CAD 2D → Revit 3D Converter"
        Height="680" Width="960"
        MinHeight="640" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6F9"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="CardGroupBox" TargetType="GroupBox">
            <Setter Property="BorderBrush" Value="#CFD8DC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding" Value="12,8,12,12"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="Label">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="0,0,6,0"/>
            <Setter Property="Foreground" Value="#37474F"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="UnitLabel" TargetType="Label">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#78909C"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="2,0,8,0"/>
        </Style>

        <Style x:Key="InputTextBox" TargetType="TextBox">
            <Setter Property="Width" Value="70"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#B0BEC5"/>
            <Setter Property="Background" Value="#FAFAFA"/>
        </Style>

        <Style x:Key="InputComboBox" TargetType="ComboBox">
            <Setter Property="Width" Value="128"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="ElementCheckBox" TargetType="CheckBox">
            <Setter Property="Margin" Value="0,6,0,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#37474F"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="BlueButton" TargetType="Button">
            <Setter Property="Background" Value="#1565C0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="GreenButton" TargetType="Button" BasedOn="{StaticResource BlueButton}">
            <Setter Property="Background" Value="#2E7D32"/>
        </Style>

        <Style x:Key="OutlineButton" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#37474F"/>
            <Setter Property="BorderBrush" Value="#B0BEC5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="StatCountLabel" TargetType="Label">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#1565C0"/>
            <Setter Property="Padding" Value="2,0,16,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="StatNameLabel" TargetType="Label">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#546E7A"/>
            <Setter Property="Padding" Value="0,0,4,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16,12,16,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="6"
                BorderBrush="#CFD8DC" BorderThickness="1"
                Padding="12,8" Margin="0,0,0,10">
            <Label Content="{Binding StatusMessage}"
                   Foreground="{Binding StatusColor}"
                   FontSize="13" FontStyle="Italic"
                   Padding="0" VerticalAlignment="Center"/>
        </Border>

        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <GroupBox Header="Thông số nhập tay" Style="{StaticResource CardGroupBox}">
                    <StackPanel Margin="0,8,0,0">
                        <WrapPanel Margin="0,0,0,10">
                            <Label Content="Chiều cao tầng 1:" Style="{StaticResource FieldLabel}" Width="140"/>
                            <TextBox Style="{StaticResource InputTextBox}" Text="{Binding FloorHeight}"/>
                            <Label Content="mm" Style="{StaticResource UnitLabel}"/>
                            <Label Content="H tầng ĐH:" Style="{StaticResource FieldLabel}" Margin="8,0,0,0"/>
                            <TextBox Style="{StaticResource InputTextBox}" Text="{Binding TypicalHeight}"/>
                            <Label Content="mm" Style="{StaticResource UnitLabel}"/>
                        </WrapPanel>

                        <WrapPanel Margin="0,0,0,10">
                            <Label Content="Số tầng:" Style="{StaticResource FieldLabel}" Width="140"/>
                            <TextBox Style="{StaticResource InputTextBox}" Text="{Binding NumberOfFloors}"/>
                            <Label Content="tầng" Style="{StaticResource UnitLabel}"/>
                            <Label Content="Độ dày sàn:" Style="{StaticResource FieldLabel}" Margin="24,0,0,0"/>
                            <TextBox Style="{StaticResource InputTextBox}" Text="{Binding SlabThickness}"/>
                            <Label Content="mm" Style="{StaticResource UnitLabel}"/>
                        </WrapPanel>

                        <WrapPanel Margin="0,0,0,10">
                            <Label Content="Base Offset cot:" Style="{StaticResource FieldLabel}" Width="140"/>
                            <TextBox Style="{StaticResource InputTextBox}" Text="{Binding ColumnBaseOffset}"/>
                            <Label Content="mm" Style="{StaticResource UnitLabel}"/>
                            <Label Content="Top Offset cot:" Style="{StaticResource FieldLabel}" Margin="24,0,0,0"/>
                            <TextBox Style="{StaticResource InputTextBox}" Text="{Binding ColumnTopOffset}"/>
                            <Label Content="mm" Style="{StaticResource UnitLabel}"/>
                        </WrapPanel>

                        <WrapPanel>
                            <Label Content="Dam (rong x cao):" Style="{StaticResource FieldLabel}" Width="140"/>
                            <TextBox Style="{StaticResource InputTextBox}" Text="{Binding BeamWidth}"/>
                            <Label Content="x" Style="{StaticResource UnitLabel}" Padding="4,0"/>
                            <TextBox Style="{StaticResource InputTextBox}" Text="{Binding BeamHeight}"/>
                            <Label Content="mm" Style="{StaticResource UnitLabel}"/>
                        </WrapPanel>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Quy ước lưới trục" Style="{StaticResource CardGroupBox}">
                    <StackPanel Margin="0,8,0,0">
                        <WrapPanel Margin="0,0,0,10">
                            <Label Content="Tên bắt đầu X:" Style="{StaticResource FieldLabel}" Width="140"/>
                            <TextBox Style="{StaticResource InputTextBox}" Text="{Binding XStartName, UpdateSourceTrigger=PropertyChanged}"/>
                            <Label Content="Hướng X:" Style="{StaticResource FieldLabel}" Margin="24,0,0,0"/>
                            <ComboBox Style="{StaticResource InputComboBox}"
                                      SelectedValuePath="Content"
                                      SelectedValue="{Binding XNamingDirection}">
                                <ComboBoxItem Content="Trái sang phải"/>
                                <ComboBoxItem Content="Phải sang trái"/>
                            </ComboBox>
                        </WrapPanel>

                        <WrapPanel>
                            <Label Content="Tên bắt đầu Y:" Style="{StaticResource FieldLabel}" Width="140"/>
                            <TextBox Style="{StaticResource InputTextBox}" Text="{Binding YStartName, UpdateSourceTrigger=PropertyChanged}"/>
                            <Label Content="Hướng Y:" Style="{StaticResource FieldLabel}" Margin="24,0,0,0"/>
                            <ComboBox Style="{StaticResource InputComboBox}"
                                      SelectedValuePath="Content"
                                      SelectedValue="{Binding YNamingDirection}">
                                <ComboBoxItem Content="Dưới lên trên"/>
                                <ComboBoxItem Content="Trên xuống dưới"/>
                            </ComboBox>
                        </WrapPanel>
                    </StackPanel>
                </GroupBox>
            </StackPanel>

            <GroupBox Grid.Column="2" Header="Tạo cấu kiện" Style="{StaticResource CardGroupBox}">
                <StackPanel Margin="0,8,0,0">
                    <CheckBox Content="Tạo Lưới trục (Grid)" IsChecked="{Binding CreateWall}" Style="{StaticResource ElementCheckBox}"/>
                    <CheckBox Content="Tạo Cột (Column)" IsChecked="{Binding CreateColumn}" Style="{StaticResource ElementCheckBox}"/>
                    <CheckBox Content="Tạo Dầm (Beam)" IsChecked="{Binding CreateBeam}" Style="{StaticResource ElementCheckBox}"/>
                    <CheckBox Content="Tạo Sàn (Floor)" IsChecked="{Binding CreateSlab}" Style="{StaticResource ElementCheckBox}"/>
                </StackPanel>
            </GroupBox>
        </Grid>

        <GroupBox Grid.Row="2" Header="Layer CAD" Style="{StaticResource CardGroupBox}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0">
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                        <Label Content="File:" Foreground="#546E7A" FontSize="12"
                               VerticalAlignment="Center" Padding="0,0,4,0"/>
                        <Label Content="{Binding DwgFileName}"
                               Foreground="#1565C0" FontSize="12" FontWeight="SemiBold"
                               VerticalAlignment="Center" Padding="0"/>
                    </StackPanel>

                    <Button DockPanel.Dock="Right"
                            Content="Áp dụng Gán Layer"
                            Style="{StaticResource BlueButton}"
                            Command="{Binding ApplyLayerCommand}"
                            IsEnabled="{Binding IsFileLoaded}"
                            Height="32" Margin="8,0,0,0"/>
                </DockPanel>

                <DataGrid Grid.Row="2"
                          ItemsSource="{Binding Layers}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserReorderColumns="False"
                          CanUserResizeRows="False"
                          SelectionMode="Single"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#ECEFF1"
                          BorderBrush="#CFD8DC" BorderThickness="1"
                          Background="White"
                          AlternatingRowBackground="#F8FAFC"
                          HeadersVisibility="Column"
                          FontSize="13" RowHeight="34">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Tên Layer trong file CAD"
                                            Binding="{Binding LayerName}"
                                            Width="*" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Số entity"
                                            Binding="{Binding EntityCount}"
                                            Width="80" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Nguồn"
                                            Binding="{Binding MappingSource}"
                                            Width="90" IsReadOnly="True"/>
                        <DataGridComboBoxColumn Header="Loại cấu kiện"
                                                SelectedItemBinding="{Binding ElementType, UpdateSourceTrigger=PropertyChanged}"
                                                Width="160">
                            <DataGridComboBoxColumn.ItemsSource>
                                <x:Array Type="system:String"
                                         xmlns:system="clr-namespace:System;assembly=mscorlib">
                                    <system:String>Bỏ qua</system:String>
                                    <system:String>Lưới trục</system:String>
                                    <system:String>Tường</system:String>
                                    <system:String>Cột</system:String>
                                    <system:String>Dầm</system:String>
                                    <system:String>Sàn</system:String>
                                </x:Array>
                            </DataGridComboBoxColumn.ItemsSource>
                        </DataGridComboBoxColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="3" Header="Thống kê" Style="{StaticResource CardGroupBox}">
            <StackPanel Orientation="Horizontal" Margin="0,6,0,2">
                <Label Content="Lưới trục:" Style="{StaticResource StatNameLabel}"/>
                <Label Content="{Binding GridCount}" Style="{StaticResource StatCountLabel}"/>
                <Label Content="Layer lưới trục:" Style="{StaticResource StatNameLabel}"/>
                <Label Content="{Binding GridLayerCount}" Style="{StaticResource StatCountLabel}"/>
                <Label Content="Cột:" Style="{StaticResource StatNameLabel}"/>
                <Label Content="{Binding ColumnCount}" Style="{StaticResource StatCountLabel}"/>
                <Label Content="Dầm:" Style="{StaticResource StatNameLabel}"/>
                <Label Content="{Binding BeamCount}" Style="{StaticResource StatCountLabel}"/>
                <Label Content="Sàn:" Style="{StaticResource StatNameLabel}"/>
                <Label Content="{Binding SlabCount}" Style="{StaticResource StatCountLabel}"/>
            </StackPanel>
        </GroupBox>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="Import DWG"
                    Style="{StaticResource OutlineButton}"
                    Command="{Binding ImportDwgCommand}"
                    Height="38" MinWidth="130"/>

            <Button Grid.Column="2"
                    Content="Đọc CAD"
                    Style="{StaticResource BlueButton}"
                    Command="{Binding ReadCadCommand}"
                    Height="38" MinWidth="120"/>

            <Button Grid.Column="4"
                    Content="Chuyển đổi sang 3D"
                    Style="{StaticResource GreenButton}"
                    Command="{Binding ConvertTo3DCommand}"
                    IsEnabled="{Binding IsFileLoaded}"
                    Height="38" MinWidth="180"/>

            <Button Grid.Column="6"
                    Content="Đóng"
                    Style="{StaticResource OutlineButton}"
                    Height="38" MinWidth="80"
                    Click="BtnClose_Click"/>
        </Grid>
    </Grid>
</Window>
